-- 1. Tabla de Ciudades
CREATE TABLE riwi_city (
    id_city SERIAL PRIMARY KEY,
    city_name VARCHAR(100) NOT NULL UNIQUE
);

-- 2. Tabla de Categorías
CREATE TABLE riwi_category (
    id_category SERIAL PRIMARY KEY,
    category_name VARCHAR(100) NOT NULL UNIQUE
);

-- 3. Tabla de Proveedores
CREATE TABLE riwi_supplier (
    id_supplier SERIAL PRIMARY KEY,
    supplier_name VARCHAR(150) NOT NULL UNIQUE,
    city_id INT NOT NULL,
    FOREIGN KEY (city_id) REFERENCES riwi_city(id_city) ON DELETE RESTRICT ON UPDATE CASCADE
);

-- 4. Tabla de Bodegas
CREATE TABLE riwi_warehouse (
    id_warehouse SERIAL PRIMARY KEY,
    warehouse_name VARCHAR(100) NOT NULL UNIQUE,
    city_id INT NOT NULL,
    FOREIGN KEY (city_id) REFERENCES riwi_city(id_city) ON DELETE RESTRICT ON UPDATE CASCADE
);

-- 5. Tabla de Productos
CREATE TABLE riwi_product (
    id_producto SERIAL PRIMARY KEY,
    product_name VARCHAR(150) NOT NULL,
    category_id INT NOT NULL,
    FOREIGN KEY (category_id) REFERENCES riwi_category(id_category) ON DELETE RESTRICT ON UPDATE CASCADE
);

-- 6. Tabla de Movimientos de Inventario
CREATE TABLE riwi_inventory_movement (
    id_movement SERIAL PRIMARY KEY,
    product_id INT NOT NULL,
    warehouse_id INT NOT NULL,
    movement_date DATE NOT NULL,
    quantity DECIMAL(10,2) NOT NULL CHECK (quantity > 0),
    movement_type VARCHAR(3) NOT NULL CHECK (movement_type IN ('IN', 'OUT')),
    unit_price DECIMAL(10,2) NOT NULL CHECK (unit_price >= 0),
    purchase_order VARCHAR(20) NOT NULL,
    FOREIGN KEY (product_id) REFERENCES riwi_product(id_producto) ON DELETE RESTRICT ON UPDATE CASCADE,
    FOREIGN KEY (warehouse_id) REFERENCES riwi_warehouse(id_warehouse) ON DELETE RESTRICT ON UPDATE CASCADE
);

-- Índices para optimización de consultas recurrentes
CREATE INDEX idx_riwi_mov_product ON riwi_inventory_movement(product_id);
CREATE INDEX idx_riwi_mov_warehouse ON riwi_inventory_movement(warehouse_id);


