-- Consulta 1: Stock disponible por producto (Entradas - Salidas)
SELECT 
    p.product_name,
    COALESCE(SUM(CASE WHEN m.movement_type = 'IN' THEN m.quantity ELSE 0 END), 0) -
    COALESCE(SUM(CASE WHEN m.movement_type = 'OUT' THEN m.quantity ELSE 0 END), 0) AS current_stock
FROM riwi_product p
LEFT JOIN riwi_inventory_movement m ON p.id_producto = m.product_id
GROUP BY p.id_producto, p.product_name;

-- Consulta 2: Movimientos de inventario con detalle de producto y bodega
SELECT 
    m.id_movement,
    m.movement_date,
    m.movement_type,
    m.quantity,
    p.product_name,
    w.warehouse_name
FROM riwi_inventory_movement m
INNER JOIN riwi_product p ON m.product_id = p.id_producto
INNER JOIN riwi_warehouse w ON m.warehouse_id = w.id_warehouse
ORDER BY m.movement_date DESC;

-- Consulta 3: Total comprado por proveedor (aqui son las órdenes de compra 'IN')
SELECT 
    s.supplier_name,
    SUM(m.quantity * m.unit_price) AS total_purchased
FROM riwi_inventory_movement m
CROSS JOIN riwi_supplier s 
WHERE m.movement_type = 'IN' 
GROUP BY s.id_supplier, s.supplier_name;

-- Consulta 4: Cantidad de movimientos registrados por bodega
SELECT 
    w.warehouse_name,
    COUNT(m.id_movement) AS total_movements
FROM riwi_warehouse w
LEFT JOIN riwi_inventory_movement m ON w.id_warehouse = m.warehouse_id
GROUP BY w.id_warehouse, w.warehouse_name
ORDER BY total_movements DESC;

-- Consulta 5: Producto con mayor volumen de compras (Entradas 'IN')
SELECT 
    p.product_name,
    SUM(m.quantity) AS total_units_bought
FROM riwi_inventory_movement m
INNER JOIN riwi_product p ON m.product_id = p.id_producto
WHERE m.movement_type = 'IN'
GROUP BY p.id_producto, p.product_name
ORDER BY total_units_bought DESC
LIMIT 1;

-- Consulta 6: Valor económico total del inventario almacenado por bodega
SELECT 
    w.warehouse_name,
    SUM(
        CASE 
            WHEN m.movement_type = 'IN' THEN (m.quantity * m.unit_price)
            WHEN m.movement_type = 'OUT' THEN -(m.quantity * m.unit_price)
            ELSE 0 
        END
    ) AS inventory_monetary_value
FROM riwi_warehouse w
LEFT JOIN riwi_inventory_movement m ON w.id_warehouse = m.warehouse_id
GROUP BY w.id_warehouse, w.warehouse_name;


-- Vista 1: Resumen analítico operativo diario
CREATE OR REPLACE VIEW view_daily_operations_summary AS
SELECT 
    movement_date,
    COUNT(id_movement) AS transactions_count,
    SUM(CASE WHEN movement_type = 'IN' THEN quantity ELSE 0 END) AS total_items_received,
    SUM(CASE WHEN movement_type = 'OUT' THEN quantity ELSE 0 END) AS total_items_shipped
FROM riwi_inventory_movement
GROUP BY movement_date;

-- Vista 2: Catálogo maestro de productos con su respectiva categoría
CREATE OR REPLACE VIEW view_product_catalog AS
SELECT 
    p.id_producto,
    p.product_name,
    c.category_name
FROM riwi_product p
INNER JOIN riwi_category c ON p.category_id = c.id_category;

-- Procedimiento Almacenado / Función para consultar proveedores de manera dinámica
CREATE OR REPLACE FUNCTION sp_get_suppliers(p_supplier_id INT DEFAULT NULL)
RETURNS TABLE(id_supplier INT, supplier_name VARCHAR, city_name VARCHAR) AS $$
BEGIN
    IF p_supplier_id IS NULL THEN
        RETURN QUERY 
        SELECT s.id_supplier, s.supplier_name, c.city_name 
        FROM riwi_supplier s
        INNER JOIN riwi_city c ON s.city_id = c.id_city;
    ELSE
        RETURN QUERY 
        SELECT s.id_supplier, s.supplier_name, c.city_name 
        FROM riwi_supplier s
        INNER JOIN riwi_city c ON s.city_id = c.id_city
        WHERE s.id_supplier = p_supplier_id;
    END IF;
END;
$$ LANGUAGE plpgsql;

